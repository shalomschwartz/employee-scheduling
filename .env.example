# Database (Neon Postgres)
# DATABASE_URL = pooled connection (host contains "-pooler") — used at runtime
# DIRECT_URL   = direct connection (no "-pooler") — used by `prisma db push` / migrations
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Invite code required to register a new manager account (leave blank to disable)
INVITE_CODE="your-invite-code-here"

# Admin secret for the /api/admin/* endpoints
ADMIN_SECRET="your-admin-secret-here"
